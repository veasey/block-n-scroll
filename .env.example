APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:GENERATE_THIS
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (matches typical docker-compose service name "db")
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=blockdb
DB_USERNAME=blockuser
DB_PASSWORD=secret

# Cache / sessions (safe defaults)
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Redis (if you have it in docker-compose)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (dev fallback)
MAIL_MAILER=log
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Timezone (optional but useful UK dev default)
APP_TIMEZONE=Europe/London